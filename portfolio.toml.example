# 持仓配置文件示例
# Portfolio Configuration Example

# ========== 账户信息 ==========
[account]
total_equity = 500000       # 总资产（元）
total_market_value = 350000 # 总市值（元）
available_cash = 150000     # 可用现金（元）
floating_pnl = 0.0          # 浮动盈亏（元）
daily_pnl = 0.0             # 当日盈亏（元）
position_ratio = 0.70       # 仓位比例
update_time = "2026-01-01 09:00"

# 说明：
# - code: 股票代码（A股6位数字，港股5位数字）
# - name: 股票名称
# - market: 市场（上海/深圳/沪港通/深港通）
# - quantity: 持仓数量（股）
# - cost_price: 成本价（元）

# 使用方法：
# 1. 运行 ./scripts/init_project.sh 自动生成配置文件
# 2. 或手动复制本文件为 portfolio.toml，修改为你的实际持仓
# 3. 运行 ./quickstart.sh risk 即可执行风控检查

[[holdings]]
code = "600519"
name = "贵州茅台"
market = "上海"
quantity = 100
cost_price = 1800.0

[[holdings]]
code = "000001"
name = "平安银行"
market = "深圳"
quantity = 1000
cost_price = 12.5

[[holdings]]
code = "00700"
name = "腾讯控股"
market = "沪港通"
quantity = 100
cost_price = 350.0

[[holdings]]
code = "159792"
name = "互联网ETF"
market = "深圳"
quantity = 10000
cost_price = 0.85
