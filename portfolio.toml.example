# 持仓配置文件示例
# Portfolio Configuration Example

# ========== 账户信息 ==========
[account]
total_equity = 500000       # 总资产（元）— 必填，风控模块依赖
total_market_value = 350000 # (可选) 总市值，仅供记录
position_ratio = 0.70       # (可选) 仓位比例，仅供记录
update_time = "2026-01-01 09:00" # (可选) 更新时间，仅供记录

# 说明：
# - code: 股票代码（A股6位数字，港股5位数字）
# - name: 股票名称
# - market: 市场（上海/深圳/沪港通/深港通）
# - quantity: 持仓数量（股）
# - cost_price: 成本价（元）
# - familiarity: (可选) 熟悉程度评估，影响个股仓位上限
#     business_model = true       商业模式优秀
#     shareholder_friendly = true 对中小投资者态度友好
#     valuation_low = true        当前估值处于历史低位/合理区间
#     trend_up = true             技术趋势处于底部或上升趋势
#   通过维度数: 0-1→12%, 2→15%, 3→18%, 4→22%  未填默认12%

# 使用方法：
# 1. 运行 ./scripts/init_project.sh 自动生成配置文件
# 2. 或手动复制本文件为 portfolio.toml，修改为你的实际持仓
# 3. 运行 ./quickstart.sh risk 即可执行风控检查
# 4. 运行 ./quickstart.sh daily-review 即可生成 AI 可消费的每日复盘输入包

[[holdings]]
code = "600519"
name = "贵州茅台"
market = "上海"
quantity = 100
cost_price = 1800.0
familiarity = {business_model = true, shareholder_friendly = true, valuation_low = false, trend_up = true}
risk_rules = {stop_loss_atr_multiplier = 1.8, trailing_stop_atr_multiplier = 2.5}

[[holdings]]
code = "000001"
name = "平安银行"
market = "深圳"
quantity = 1000
cost_price = 12.5

[[holdings]]
code = "00700"
name = "腾讯控股"
market = "沪港通"
quantity = 100
cost_price = 350.0
familiarity = {business_model = true, shareholder_friendly = true, valuation_low = true, trend_up = true}

[[holdings]]
code = "159792"
name = "互联网ETF"
market = "深圳"
quantity = 10000
cost_price = 0.85

# ========== 待买入观察列表（可选） ==========
# target_buy_price: 回调到该价格及以下，提示关注买点
# breakout_price: 向上突破该价格，提示突破买点
# signal_rules: 预留给自定义观察信号插件的参数 table

[[watchlist]]
code = "300750"
name = "宁德时代"
market = "深圳"
target_buy_price = 180.0
breakout_price = 205.0
signal_rules = {preferred_strategy = "target_buy"}
notes = "等回调缩量企稳，或放量突破后跟踪"

[[watchlist]]
code = "00700"
name = "腾讯控股"
market = "沪港通"
target_buy_price = 320.0
notes = "只做核心资产观察，不追高"
